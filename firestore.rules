rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /days/{dateKey} {
        allow read, write: if isOwner(uid);

        match /entries/{entryId} {
          allow read, write: if isOwner(uid);
        }
      }

      match /savedMeals/{mealId} {
        allow read, write: if isOwner(uid);
      }
    }
  }
}

